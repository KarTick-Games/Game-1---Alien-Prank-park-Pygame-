# =============================================================================
# PROGRESS / UNLOCK SYSTEM
# Saves which levels have been completed to a JSON file beside main.py.
# Only active when DEVELOPER_MODE = False.
# =============================================================================

_SAVE_PATH = os.path.join(os.path.dirname(os.path.abspath(__file__)), 'game_save.json')

# Act 1 has levels 1–10. Extend this list if you add more acts/levels.
_ALL_LEVEL_NUMBERS = list(range(1, 11))

def _load_progress():
    """Return a set of completed level numbers loaded from disk."""
    try:
        if os.path.exists(_SAVE_PATH):
            with open(_SAVE_PATH, 'r') as f:
                data = json.load(f)
            return set(data.get('completed', []))
    except Exception:
        pass
    return set()

def _save_progress(completed_set):
    """Write the set of completed level numbers to disk, preserving other keys."""
    try:
        # Load existing data first so we don't wipe level9 keys
        existing = {}
        if os.path.exists(_SAVE_PATH):
            try:
                with open(_SAVE_PATH, 'r') as f:
                    existing = json.load(f)
            except Exception:
                existing = {}
        existing['completed'] = sorted(completed_set)
        with open(_SAVE_PATH, 'w') as f:
            json.dump(existing, f, indent=2)
    except Exception:
        pass

def mark_level_complete(level_num):
    """
    Call this at the end of every level to record it as completed.
    Safe to call even in DEVELOPER_MODE (it just won't affect unlock gates).
    """
    completed = _load_progress()
    completed.add(level_num)
    _save_progress(completed)

def is_level_unlocked(level_num):
    """
    Return True if the player may play level_num.

    DEVELOPER_MODE = True  → always True.
    DEVELOPER_MODE = False → True only if level_num == 1, OR the previous
                             level number appears in the completed set.
    """
    if DEVELOPER_MODE:
        return True
    if level_num <= 1:
        return True
    completed = _load_progress()
    return (level_num - 1) in completed


