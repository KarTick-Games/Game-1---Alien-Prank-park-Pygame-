# =============================================================================
# SCALING HELPERS
# =============================================================================

def win_size():
    return screen.get_size()

def scale_pos(pos):
    rw, rh = win_size()
    scale = min(rw / VWIDTH, rh / VHEIGHT)
    ox = (rw - VWIDTH  * scale) / 2
    oy = (rh - VHEIGHT * scale) / 2
    return ((pos[0] - ox) / scale, (pos[1] - oy) / scale)

def blit_canvas():
    rw, rh = win_size()
    scale  = min(rw / VWIDTH, rh / VHEIGHT)
    sw, sh = int(VWIDTH * scale), int(VHEIGHT * scale)
    scaled = pygame.transform.scale(canvas, (sw, sh))
    screen.fill((0, 0, 0))
    screen.blit(scaled, ((rw - sw) // 2, (rh - sh) // 2))
    pygame.display.flip()

def get_events():
    evs = []
    for e in pygame.event.get():
        if e.type in (pygame.MOUSEBUTTONDOWN, pygame.MOUSEBUTTONUP, pygame.MOUSEMOTION):
            e = pygame.event.Event(e.type, {**e.__dict__, 'pos': scale_pos(e.pos)})
        evs.append(e)
    return evs


