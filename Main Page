                nf = num_font.render(str(lnum), True, act['col'])
                canvas.blit(nf, (lrect.x+12, lrect.y+8))

                nmf = eng_hud_font.render(lname, True, WHITE)
                canvas.blit(nmf, (lrect.x+12, lrect.y+48))

                at = small_font.render(f"{act['name']}", True,
                    tuple(min(255, c+60) for c in act['col']))
                canvas.blit(at, (lrect.right-at.get_width()-8, lrect.y+8))

                # Show a ✓ badge if this level is already completed
                if not DEVELOPER_MODE and lnum in _load_progress():
                    ck = small_font.render("✓", True, GREEN)
                    canvas.blit(ck, (lrect.right - ck.get_width() - 6, lrect.bottom - ck.get_height() - 4))

        # -- Act description banner -----------------------------------------
        desc_y = gy0 + 2*(CELL_H+12) + 8
        pygame.draw.rect(canvas, (15,15,35), (gx0, desc_y, grid_total_w, 36), border_radius=6)

        if not act['locked']:
            pygame.draw.rect(canvas, act['col'], (gx0, desc_y, grid_total_w, 36), 2, border_radius=6)
            desc = btn_font.render(f"🌌  {act['name']} — {act['sub']}", True, act['col'])
            canvas.blit(desc, (VWIDTH//2 - desc.get_width()//2, desc_y+8))
        else:
            lk3 = btn_font.render(
                f"🔒  {act['name']} — {act['sub']}  (Complete previous acts to unlock)",
                True, DARK_GRAY)
            canvas.blit(lk3, (VWIDTH//2 - lk3.get_width()//2, desc_y+8))

        # Back button
        draw_button(back_btn, "◀ BACK")

        # Reset progress button (normal mode only, so players can restart)
        if not DEVELOPER_MODE:
            mx_now, my_now = pygame.mouse.get_pos()
            r_hov = reset_btn.collidepoint(scale_pos((mx_now, my_now)))
            pygame.draw.rect(canvas, (80,20,20) if r_hov else (50,10,10),
                             reset_btn, border_radius=6)
            pygame.draw.rect(canvas, RED, reset_btn, 2, border_radius=6)
            rt = small_font.render("Reset Progress", True, WHITE)
            canvas.blit(rt, (reset_btn.centerx - rt.get_width()//2,
                              reset_btn.centery - rt.get_height()//2))

        # -- Events ---------------------------------------------------------
        for event in get_events():
            if event.type == pygame.QUIT:
                pygame.quit(); sys.exit()

            if event.type == pygame.MOUSEBUTTONDOWN:
                mpos = event.pos

                if back_btn.collidepoint(mpos):
                    return home_screen()

                # Reset progress (normal mode only)
                if not DEVELOPER_MODE and reset_btn.collidepoint(mpos):
                    _save_progress(set())   # wipe saved data

                for ai, tr in enumerate(act_rects):
                    if tr.collidepoint(mpos):
                        selected_act = ai

                for lnum, lname, actually_unlocked, lrect in level_rects:
                    if lrect.collidepoint(mpos) and actually_unlocked and not act['locked']:
                        fn = level_fns.get(lnum)
                        if fn:
                            fn()

        blit_canvas()


