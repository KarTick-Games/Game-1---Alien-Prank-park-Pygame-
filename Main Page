def costume_menu():
    global current_costume

    costumes = [
        ("alien","Alien"), ("santa","Santa"), ("suit","Suit"),
        ("robot","Robot"), ("zombie","Zombie"), ("football","Football"),
        ("clown","Clown"), ("ninja","Ninja"), ("princess","Princess"),
    ]

    cols  = 5;  box_w = 130;  box_h = 130;  pad = 18
    total_w   = cols * box_w + (cols-1) * pad
    start_x   = (VWIDTH  - total_w) // 2
    start_y   = 200

    boxes = []
    for i, (key, label) in enumerate(costumes):
        r, ci = divmod(i, cols)
        rx = start_x + ci*(box_w+pad)
        ry = start_y + r*(box_h+pad+20)
        boxes.append((key, label, pygame.Rect(rx, ry, box_w, box_h)))

    while True:
        clock.tick(FPS)
        draw_space()

        title = title_font.render("CHOOSE COSTUME", True, WHITE)
        canvas.blit(title, (VWIDTH//2 - title.get_width()//2, 120))

        for key, label, rect in boxes:
            border_col = YELLOW if key == current_costume else GRAY
            pygame.draw.rect(canvas, (30,30,60), rect, border_radius=8)
            pygame.draw.rect(canvas, border_col, rect, 3, border_radius=8)
            draw_player(rect.x + (box_w-40)//2, rect.y+18, costume=key)
            lbl = name_font.render(label, True, WHITE)
            canvas.blit(lbl, (rect.centerx - lbl.get_width()//2, rect.bottom-22))

        for event in get_events():
            if event.type == pygame.QUIT:
                pygame.quit(); sys.exit()
            if event.type == pygame.MOUSEBUTTONDOWN:
                for key, label, rect in boxes:
                    if rect.collidepoint(event.pos):
                        current_costume = key
                        return

        blit_canvas()


